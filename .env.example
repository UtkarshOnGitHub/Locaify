# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000

# WhatsApp Configuration
VERIFY_TOKEN=your_webhook_verify_token_here
GENERAL_TOKEN=your_whatsapp_business_api_token_here
PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
GRAPH_API_VERSION=v25.0

# Game Deal API
CHEAPSHARK_API_BASE_URL=https://www.cheapshark.com/api/1.0

# Groq LLM Configuration (future conversational intent parsing)
# Get your free key from: https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/locaify

# Deal Monitoring Worker
TRACKING_CRON=0 */1 * * *
TRACKING_MAX_TRACKS_PER_RUN=25
TRACKING_REQUEST_TIMEOUT_MS=12000
TRACKING_REQUEST_DELAY_MS=1000
TRACKING_CURRENCY=USD
TRACKING_REGION=GLOBAL
TRACKING_BYPASS_PRICE_CHECK=false
